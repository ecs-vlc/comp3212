\begin{slide}
\section{Random Instances and Distributions}

\begin{PauseHighLight}
  \begin{itemize}
  \item The stochastic differential equation (aka diffusion equation)
    describes $X(t)$ in terms of a second stochastic process
    $W(t)$\pause
  \item $W(t)$ is known as a Weiner measure it has the distribution
    \begin{align*}
      f\!\left(\strut W(\Delta t + t_0)-W(t_0)=x\right) = \mathcal{N}(x|
      0, \Delta t)
    \end{align*}
  \item where $\mathcal{N}(x|\mu,\sigma^2)$ is a normal (Gaussian)
    distribution with mean $\mu$ and variance $\sigma^2$\pause
  \item However $W(t)$ varies from instance to instance so even if we
    can solve the stochastic differential equation the solution is
    stochastic\pause 
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Fokker-Planck Equation}

\begin{PauseHighLight}
  \begin{itemize}
  \item Although we cannot obtain a closed form solution
    $X(t) = g(W(t))$, we can obtain a solution for the the probability
    distribution for $X(t)$
    \begin{align*}
      f(x,t)\, \dd x = \Prob{x<X(t)<x + \dd x}\pause
    \end{align*}
  \item The dynamics of $f(x,t)$ going forward in time is given by the
  \emph{Fokker-Planck} or \emph{forward Kolmogorov} equation
  \begin{align*}
    \frac{\partial f(x,t)}{\partial t} = -\frac{\partial \left(\strut
        a(x)\,f(x,t)\right)}{\partial x} + \frac{1}{2}\,
    \frac{\partial^2 \left(\strut b^2(x)\,f(x,t)\right)}{\partial x^2}\pause
  \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-1]{Going Back}

\begin{PauseHighLight}
  \begin{itemize}
  \item Diffusion isn't reversible so the equations for going back in
    time are different\pause---the \emph{backward Kolmogorov} equation
    \begin{displaymath}
      \frac{\partial f(x,-t)}{\partial t} =
      - a(x)\, \frac{\partial f(x,-t)}{\partial x}
      - \frac{1}{2} b^2(x)\, \frac{\partial^2 f(x,-t)}{\partial x^2}\pause
    \end{displaymath}
  \item The backward equation is very useful to study systems with
    \textit{absorbing states}\pause
  \item It can be used to calculate the probability of finishing in an
    absorbing state and the time taken to reach that state\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Using Fokker-Planck}

\begin{PauseHighLight}
  \begin{itemize}
  \item The Fokker-Planck equation helps in that rather than work with
    the weird world of stochastic differential equation we can work with
    the well understood partial differential equations (PDEs)\pause
  \item The solution describes how the evolution of a PDF evolves over
    time\pause
  \item Unfortunately it is often hard to solve PDEs in closed form
    (they usually involve series expansions in nasty polynomials)\pause
  \item We often have to solve them numerically\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

