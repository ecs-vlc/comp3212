\begin{slide}
\section[-1]{Diffusion Models}
\toptarget{diffusion}

\begin{PauseHighLight}
  \begin{itemize}
  \item Markov analysis quickly becomes intractable\pause
  \item For weak selection and small mutation rates we can model the
    system using a \textit{stochastic difference equation}\pause
  \item Let $X(t)$ be the proportion of mutants at time $t$\pause
  \item We make the assumption that at time $t+\Delta t$ the proportion of
    mutants is given by
    \begin{align*}
      X(t+\Delta t) = X(t) + a(X(t)) \Delta t + b(X(t)) \Delta W(t)\pause
    \end{align*}
  \item where $\Delta W(t)$ is a random variable with mean 0 and
    variance $\Delta t$\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-2]{Random Variables}

\begin{PauseHighLight}
  \begin{itemize}
  \item $X(t)$ (the proportion of mutants at time $t$) is a random
    variable\pause
  \item That is, it varies from realisation to realisation\pause
  \item $X(t)$ will be distributed according to a probability density
    $f(X(t))$\pause
    \begin{center}
      \includegraphics[width=0.6\linewidth]{probabilityDensity}
    \end{center}
  \item We denote its average or \emph{expectation} as
    \begin{align*}
      \av{X(t)} = \int X(t) \, f(X(t))\, \dd t\pause
      = \left\langle X(t) \right\rangle \pauseb
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}



%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-1]{Naming and Mis-naming}

\begin{PauseHighLight}
  \begin{itemize}
  \item On average
    \begin{align*}
      \av{X(t+\Delta t)} = X(t) + a(X(t)) \Delta t\pause
    \end{align*}
    this defines the function $a(X(t))$\pause
  \item Physicists call this the \textit{drift term}\pause
  \item The variance in $X(t+\Delta t)$ is given by
    \begin{align*}
      \av{X^2(t+1)} - \av{X(t+1)}^2 = b^2(X(t)) \Delta t\pause
    \end{align*}
    this defines the function $b(X(t))$\pause
  \item Population geneticists call $b(X(t)) \Delta W(t)$
  \textit{genetic drift}\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Fisher-Wright Average}

\begin{PauseHighLight}
  \begin{itemize}
  \item For the Fisher-Wright model we have
    \begin{align*}
      \Prob{X(t+1)=x} = \Prob{n'=Px} \pause
      = \binom{P}{Px} p_{sm}^{Px} ( 1 - p_{sm})^{P(1-x)} \pause
    \end{align*}
  \item $\Delta t =1$\pause
  \item Taking averages
    \begin{align*}
      a(X(t)) &= \av{X(t+1)}-X(t) \pause
      = p_{sm} - X(t) \pause \\
      &= \frac{(u - (u+v-s+u\,s) X(t) + s X^2(t)
        \bigr)}{1+s\,X(t)}\pause
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-1]{Fisher-Wright Variance}

\begin{PauseHighLight}
  \begin{itemize}
  \item The variance of a binomial is given by
    \begin{align*}
      b^2(X(t)) = \av{X^2(t+1)} - \av{X(t+1)}^2 \pause
      = \frac{p_{sm}(1-p_{sm})}{P}\pause
    \end{align*}
  \item If $s$, $u$ and $v$ are small then $p_{sm}\approx X(t)$ so
    \begin{align*}
      b^2(X(t)) \approx \frac{X(t)\left(\strut 1-X(t)\right)}{P}\pause
    \end{align*}
  \item Recall
        \begin{align*}
      X(t+\Delta t) = X(t) + a(X(t)) \Delta t + b(X(t)) \Delta W(t)\pause
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}


%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Continuous Time}

\begin{PauseHighLight}
  \begin{itemize}
  \item Taking the limit $\Delta t\rightarrow 0$ we obtain a (It\^o)
    \textit{stochastic differential equation} (SDE)
    \begin{align*}
      \dd X(t) = a(X(t))\, \dd t + b(X(t))\, \dd W(t)\pause
    \end{align*}
  \item This has to be viewed as a formal definition---its precise
    meaning is rather technical\pause
  \item When we treat $X(t)$ as a function of $t$ then the function is
    known as a \emph{stochastic process}\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Why SDE Work}

\begin{PauseHighLight}
  \begin{itemize}
  \item SDE's model fluctuating systems using two terms
    \begin{itemize}
    \item The mean change described by $a(X(t))\,\dd t$ which we can model
      accurately (it become more accurate in large populations where the
      difference between discrete and continuous time is
      negligible)\pause
    \item Fluctuations $b(X(t))\, \dd W(t)$ which are assumed to be
      normally distributed\pause
    \end{itemize}
  \item Although our fluctuations are not normally distributed the
    accumulative effect of many fluctuations will be very close to
    normally distributed due to the central limit theorem\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}


%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Recap}

\begin{PauseHighLight}
  \begin{itemize}
  \item There are a lot of techniques for dealing with 
    \textit{stochastic differential equation}
    \begin{align*}
      \dd X(t) = a(X(t))\, \dd t + b(X(t))\, \dd W(t)\pause
    \end{align*}
  \item The Fisher-Wright model is well approximated by an SDE with
    \begin{align*}
      a(X(t)) &= \frac{(u - (u+v-s+u\,s) X(t) + s X^2(t)
        \bigr)}{1+s\,X(t)} \\
      b^2(X(t)) &= \frac{X(t)\left(\strut 1-X(t)\right)}{P}\pause
    \end{align*}
  \item Unfortunately it is too difficult to obtain a direct solution of
    the form $X(t) = g(W(t))$\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}



