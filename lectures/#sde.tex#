\begin{slide}
\section{Steady State}

\begin{PauseHighLight}
  \begin{itemize}
  \item Although solving PDFs are in general hard\pause
  \item The problem simplifies if we consider the \textit{steady state}
    given by
    \begin{align*}
      \frac{\partial f(x,t)}{\partial t} = 0\pause
    \end{align*}
  \item This (usually) happens when $t\rightarrow \infty$\pause
  \item Our Fokker-Planck equation then becomes
  \begin{align*}
    \frac{\partial f(x,t)}{\partial t} = -\frac{\partial \left(\strut
        a(x)\,f(x,t)\right)}{\partial x} + \frac{1}{2}\,
    \frac{\partial^2 \left(\strut b^2(x)\,f(x,t)\right)}{\partial x^2} =
    0\pause
  \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Steady State Solution}

\begin{PauseHighLight}
  \begin{itemize}
  \item The steady state solution $f_{eq}(x) = \lim_{t\rightarrow
      \infty} f(x,t)$ does not depend on $t$ so the Fokker-Planck
    equation becomes an ordinary differential equation
    \begin{align*}
      -\frac{\dd  \left(\strut
      a(x)\,f_{eq}(x)\right)}{\dd  x} + \frac{1}{2}\,
      \frac{\dd ^2 \left(\strut b^2(x)\,f_{eq}(x)\right)}{\dd  x^2} =
      0\pause
    \end{align*}
  \item Which has a solution
    \begin{align*}
      f_{eq}(x) \propto \frac{1}{b^2(x)} \, \E{2 \int_{1/2}^x
      \frac{a(y)}{b^2(y)} \dd y}\pause
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}


%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Steady State for Fisher-Wright}

\begin{PauseHighLight}
  \begin{itemize}
  \item Assuming $s$, $u$ and $v$ are small, then expanding to first
    order
    \begin{align*}
      a(X) &= \av{\Delta X}/\Delta t \approx -v \,X + u (1-X) + s X (1-X)\\
      b(X) &= \left(\av{(\Delta X)^2}-\av{\Delta X}^2\right)/\Delta t
             \approx \frac{X(1-X)}{P}\pause
    \end{align*}
  \item Using these values we find
    \begin{align*}
      f_{eq}(x) = \frac{x^{2\,P\,u-1} \, (1-x)^{2\,P\,v-1} \,
        \e{2\,P\,s\,x}}{B(2\,P\,u, 2\,P\,v) \, F(2\,P\,u;2\,P(u+v);2\,P\,s)}
      \pause
    \end{align*}
  \item The denominator involves special function, but is just a
    normalisation constant\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{What's the Point}

\begin{PauseHighLight}
  \begin{itemize}
  \item This seems a long journey to get a complicate formula, but this
    tells us the final distribution as a function of the parameters of
    our model\pause
  \item As evolution is slow the steady-state solution is often what we
    observe\pause
  \item With more work we can also obtain an understanding of the
    dynamics (e.g. typical take over time)\pause
  \item One very important observation is that the take over times are
    fast even when the mutants have only a small advantage\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}


%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Sickle-Cell Anaemia}

\begin{PauseHighLight}
  \begin{itemize}
  \item One classic example of population genetics is to understand the
    presences of sickle-cell anaemia\pause
  \item This is caused by a particular mutation, but carriers only suffer
    if they have two copies of the mutation\pause
  \item Nevertheless, sickle-cell anaemia is very serious and is
    disadvantageous enough that it should be selected out of the
    population\pause
  \item Except, when a carrier has a single copy it helps fight against
    malaria and so provides a selective advantage\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

