size(500,0);
import myutil;

void bb() {
  draw(box((-12,-7), (12, 8.5)), white);
}

path protein = (-1,0)--(-1.1,-0.1)..(-2,-0.5)..(-0.5,-1)--(-0.5,-1.1)..(-0.7,-1.5)..(0,-2)..(0.7,-1.5)..(0.5,-1.1)--(0.5,-1)..(2,-0.5)..(1.1,-0.1)--(1,0)..(5,-3)..(0,-6)..(-5,-3)..cycle;

bb();
filldraw(protein, gray);

int T = 40;

void signal(path p, int i) {
  real t = i*length(p)/T;
  filldraw(circle(point(p, t), 0.4), red);
}

path p1 = (-10, -2)..(-8,4)..(-3,2)..(0,-0.1)..(1,-1)..(0,0)..(-2,3);
path p2 = (3,1)..(0,0)..(0,-1.5)..(0,0.2)..(6,6)..(9,2)..(10,-1);
path p3 = (10,6)..(-2,5)..(-7,-2);

for(int t=0; t<=T; ++t) {
  erase();
  bb();
  filldraw(protein, gray);
  signal(p1, t);
  signal(p2, t);
  signal(p3, t);
  ship();
}  

path[] traj = {(-7,-2)..(-2,5)..(10,6),
	       (1,1)..(0,0)..(0,-1.5)..(0,0.2)..(1,1)..(3,4)..(6,6)..(9,2)..(10,-1),
	       (10,-1)..(6,2)..(9,2)..(0.1,-0.1)::(0,-1.4)..(0,-1.3)..(0,-1.5),
	       (-10, -2)..(-8,4)..(-3,2)..(-0.1,0)..(1,-0.9)..(1,-0.8)..(1,-0.7),
	       (-2,3)..(-6,6)::(-9, -4),
	       (-3,8)..(1,5)..(2,2)..(0,0)..(-0.9,-0.8)..(-1,-0.7)..(-0.9,-0.9),
	       (6,3)..(8,7)..(10,3),
	       (10,5)..(2,5)..(-7,-2)};

for(int t=0; t<=T; ++t) {
  erase();
  bb();
  filldraw(protein, gray);
  for(int i=0; i<traj.length; ++i) {
    signal(traj[i], t);
  }
  ship();
}  
