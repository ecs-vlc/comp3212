\begin{slide}
\section{Nullclines}

\begin{PauseHighLight}
  \begin{itemize}
  \item To get a better understanding of the dynamics we look at the
    \emph{nullclines} defined by $\dd X_i/\dd t=0$\pause
  \item In our system
    {\small \begin{align*}
      \frac{\dd X_1}{\dd t} &= \frac{k_1}{1+(X_2/K)^n} - k_3 \,
                                 X_1- k_5\,X_1 = 0
              & &\Rightarrow &
     X_1 &= \frac{k_1}{(k_3+k_5)(1+(X_2/K)^n)}\pause
              \\ \\
       \frac{\dd X_2}{\dd t} &= k_2 + k_5\,X_1 - k_4\,X_2=0
              &&\Rightarrow &
     X_2 &= \frac{k_2 + k_5\,X_1}{k_2}\pause
            \end{align*}}
   \item The intersection of the nullclines defines the stationary points\pause

  \end{itemize}
\end{PauseHighLight}

\end{slide}


