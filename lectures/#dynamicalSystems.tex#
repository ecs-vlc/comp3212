\begin{slide}
\section[-2]{Expand Around Fixed-Point}

\begin{PauseHighLight}
  \begin{itemize}
  \item To study stability at a fixed-point $\bm{X}^*$ we look at what
    happens when we make a small perturbation $\bm{\epsilon}$
    \begin{align*}
      \frac{\dd X_i}{\dd t} = f_i(\bm{X}^*+\bm{\epsilon})\pause
      \approx f_i(\bm{X}^*) + \bm{\epsilon}^\tr \grad f_i(\bm{X}^*)\pause
      = \bm{\epsilon}^\tr \grad f_i(\bm{X}^*)
    \end{align*}
    since $f_i(\bm{X}^*)=0$ (we are at a fixed-point)\pause
  \item Where
    \begin{align*}
      \bm{\epsilon}^\tr \grad f_i(\bm{X}^*) = \epsilon_1\,\frac{\partial
      f_i(\bm{X}^*)}{\partial X_1} +  \epsilon_2\,\frac{\partial
      f_i(\bm{X}^*)}{\partial X_2} + \cdots +  \epsilon_n\,\frac{\partial
      f_i(\bm{X}^*)}{\dd X_n}\pause
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}
%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-2]{Jacobian}

\begin{PauseHighLight}
  \begin{itemize}
  \item In vector form
    \begin{align*}
      \frac{\dd \bm{X}}{\dd t} = \bm{f}(\bm{X}^*+\bm{\epsilon})\pause
      =  \mat{J}\, \bm{\epsilon} + O(\bm{\epsilon}^2)\pause
    \end{align*}
  \item where $\mat{J}$ is the \emph{Jacobian} matrix with elements
    \begin{align*}
      J_{ij} = \left. \frac{\partial f_i(\bm{X})}{\partial X_j}\right|_{\bm{X}=\bm{X}^*}\pause
    \end{align*}
  \item Note that this is just saying
    \begin{align*}
       \frac{\dd X_i}{\dd t} \approx  \epsilon_1\,\frac{\partial
      f_i(\bm{X}^*)}{\partial X_1} +  \epsilon_2\,\frac{\partial
      f_i(\bm{X}^*)}{\partial X_2} + \cdots +  \epsilon_n\,\frac{\partial
      f_i(\bm{X}^*)}{\dd X_n}\pause
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Linear Approximation}

\begin{PauseHighLight}
  \begin{itemize}
  \item Let $\bm{\epsilon}(t) = \bm{X}(t) - \bm{X}^*$ then (since $\dd
    \bm{\epsilon}(t) = \dd \bm{X}(t)$)
    \begin{align*}
      \frac{\dd \bm{\epsilon}(t)}{\dd t} = \frac{\dd \bm{X}(t)}{\dd t}
      \approx \mat{J}\, \bm{\epsilon}(t)\pause
    \end{align*}
  \item To solve this we note that we can write most square matrices
    $\mat{J}$ as
    \begin{align*}
      \mat{J} = \mat{V} \mat{\Lambda}\,\mat{V}^{-1}\pause
    \end{align*}
  \item Where $\mat{\Lambda}$ is a diagonal matrix whose elements
    $\Lambda_{ii}=\lambda_i$ are eigenvalues of $\mat{J}$ and the
    columns of $\mat{V}$ are the eigenvectors\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-1]{Eigensystem of a General Matrix}

\begin{PauseHighLight}
  \begin{itemize}
  \item For a general (non-symmetric) matrix $\mat{M}$ the vector
    $\bm{v}_i$ is an (right-handed) eigenvector if
    \begin{align*}
      \mat{M} \,\bm{v}_i = \lambda_i \, \bm{v}_i\pause
    \end{align*}
  \item There are also left-handed eigenvectors $\bm{u}_i$ with the same
    eigenvalues, $\lambda_i$, such that
    \begin{align*}
      \bm{u}_i^\tr \, \mat{M} = \lambda_i \, \bm{u}_i^\tr \pause
    \end{align*}
  \item In general $\bm{v}_i\neq\bm{u}_i$ although if
    $\lambda_i\neq\lambda_j$ then $\bm{u}_i^\tr \bm{v}_j=0$\pause
  \item The eigenvalues and eigen-vectors are either real or exist
    in complex conjugate pairs $\lambda_j = \lambda_i^*$ and $\bm{v}_j
    = \bm{v}_i^*$\pause
  \end{itemize}
\end{PauseHighLight}
\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-2]{Matrix Decomposition}

\begin{PauseHighLight}
  \begin{itemize}
  \item If we write\vspace*{-1cm}
    {\small
    \begin{align*}
      \mat{V} &=
      \begin{pmatrix}
        \bm{v}_1 & \bm{v}_2 & \cdots & \bm{v}_n
      \end{pmatrix} &
      \mat{\Lambda} &=
                      \begin{pmatrix}
                        \lambda_1 & 0 & \cdots & 0 \\
                        0 & \lambda_2, & \cdots &0 \\
                        \vdots & \vdots & \ddots &0 \\
                        0 & 0 & \cdots & \lambda_n
                      \end{pmatrix}
    \end{align*}}\vspace*{-1cm}
    \item Then $\mat{M} = \mat{V} \,
      \mat{\Lambda}\,\mat{V}^{-1} 
      = \mat{V}\,\mat{\Lambda}\,\mat{U}
      = \mat{U}^{-1}\,\mat{\Lambda}\,\mat{U}$
    \item where $\mat{U} = \mat{V}^{-1}$ has rows equal to
      $\bm{u}_i^\tr$\pause
    \item Multiplying $\mat{M}$ on the right by $\mat{V}$ we find
      \begin{align*}
        \mat{M} \, \mat{V}
        &= (\mat{V} \,\mat{\Lambda}\,\mat{V}^{-1}) \, \mat{V}
         =  \mat{V}\, \mat{\Lambda} &\Rightarrow&
        &
        \mat{M} \,\bm{v}_i &= \lambda_i \, \bm{v}_i\pause
      \end{align*}
    \item Multiplying $\mat{M}$ on the left by $\mat{U} = \mat{V}^{-1}$
      \begin{align*}
        \mat{U}\,\mat{M} &= \mat{U}\,(\mat{U}^{-1}
                           \,\mat{\Lambda}\,\mat{U})
                           =\mat{\Lambda}\,\mat{U} &\Rightarrow&
        &
         \bm{u}_i^\tr \, \mat{M} &= \lambda_i \, \bm{u}_i^\tr \pause
      \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}



%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-2]{Linearised Solution}

\begin{PauseHighLight}
  \begin{itemize}
  \item Multiply the linear approximation by $\mat{V}^{-1}$
    \begin{align*}
    \frac{\dd \bm{\epsilon}(t)}{\dd t}
      &= \mat{V} \mat{\Lambda}\,\mat{V}^{-1}\, \bm{\epsilon}(t)\pause
    & \Rightarrow &&
      \frac{\dd \mat{V}^{-1}\bm{\epsilon}(t)}{\dd t} 
      &\approx \mat{\Lambda}\, \mat{V}^{-1}\bm{\epsilon}(t)\pause
    \end{align*}
  \item Writing $\hat{\bm{\epsilon}}(t) = \mat{V}^{-1}\bm{\epsilon}(t)$ then
    \begin{align*}
      \frac{\dd \hat{\bm{\epsilon}}(t)}{\dd t} 
      &\approx \mat{\Lambda}\, \hat{\bm{\epsilon}}(t) & &\text{or} &
      \frac{\dd \hat{\epsilon}_i(t)}{\dd t} 
      &\approx \lambda_i\, \hat{\epsilon_i}(t)\pause
    \end{align*}
  \item With solution
    \begin{align*}
      \hat{\epsilon}_i(t) \approx \e{\lambda_i\,t}
      \,\hat{\epsilon}_i(0)\pause
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}

