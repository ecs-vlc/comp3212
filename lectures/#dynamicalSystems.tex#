\begin{slide}
\section[-2]{Two Species}

\begin{PauseHighLight}
  \begin{itemize}
  \item Consider the simple system
    \begin{align*}
      \varnothing &\goesto{k(X_2)} X_1 &
      X_1 &\goesto{k_3} \varnothing & X_1 &\goesto{k_5} X_2 \\
      \varnothing &\goesto{k_2} X_2 & X_2 &\goesto{k_4} \varnothing &&\pause
    \end{align*}
  \item Where $X_2$ represses the expression of $X_1$
    {\small \begin{align*}
      k(X_2) &= \frac{k_1}{1+(X_2/K)^n} \hspace{2cm} \raisebox{-1cm}{\includegraphics[width=0.3\linewidth]{repressor_k}}\pause
    \end{align*}}
  \item Leading to the coupled ODEs
    {\small \begin{align*}
      \frac{\dd X_1(t)}{\dd t} &= f_1(X_1,X_2) =  \frac{k_1}{1+(X_2(t)/K)^n} - k_3 \,
                                 X_1(t)- k_5\,X_1(t) \\
       \frac{\dd X_2(t)}{\dd t} &= f_2(X_1,X_2) = k_2 + k_5\,X_1(t) - k_4\,X_2(t)\pause
    \end{align*}}
  \end{itemize}
\end{PauseHighLight}

\end{slide}

