\section{Autocatalysis}

\begin{PauseHighLight}
  \begin{itemize}
  \item Recall the autocatalytic system
    \begin{align*}
    \frac{\dd X_1(t)}{\dd t} &= k_0 -
       k_1\,\left(1+\left(\frac{X_2(t)}{K}\right)^n\right)\,X_1(t) \\
    \frac{\dd X_2(t)}{\dd t} &=
       k_1\,\left(1+\left(\frac{X_2(t)}{K}\right)^n\right)\,X_1(t) -k_2\,X_2(t)\pause
    \end{align*}
  \item With $k_0=8$, $k_1=1$, $K=1$, $k_2=5$\pause
  \item We consider what happens when we vary $n$\pause

  \end{itemize}
\end{PauseHighLight}

