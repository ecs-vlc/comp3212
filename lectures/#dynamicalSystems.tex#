\begin{slide}
\section[-2]{Incidentally\ldots}

\begin{PauseHighLight}
  \begin{itemize}
  \item A property of traces is\vspace*{-0.3cm}
    {\small
    \begin{align*}
      \Tr \mat{A}\,\mat{B} = \sum_{i,j} A_{ij}\,B_{ji} \pause= \sum_{i,j}
      B_{ji}\,A_{ij} \pauseb= \Tr \mat{B} \, \mat{A}\pauseb
    \end{align*}}\vspace*{-0.7cm}
  \item Using $\mat{J} = \mat{V}\,\mat{\Lambda}\mat{V}^{-1}$\vspace*{-0.3cm}
    {\small \begin{align*}
      \Tr \mat{J} = \Tr \mat{V}\,\mat{\Lambda}\,\mat{V}^{-1} \pause
      = \Tr \mat{V}^{-1}\,\mat{V}\,\mat{\Lambda} \pauseb
      = \Tr \mat{\Lambda}\pauseb =  \sum_i \lambda_i\pauseb
    \end{align*}}\vspace*{-0.7cm}
  \item Two properties of determinants is that $|\mat{A}\,\mat{B}| =
    |\mat{A}|\,|\mat{B}|$ and $|\mat{M}^{-1}| = |\mat{M}|^{-1}$ thus\vspace*{-0.3cm}
    {\small \begin{align*}
      |\mat{J}|= |\mat{V}|\,|\mat{\Lambda}|\,|\mat{V}^{-1}|\pause =
      |\mat{\Lambda}|\pauseb = \prod_i \lambda_i\pauseb
    \end{align*}}\vspace*{-0.7cm}
  \item If $\lambda_{1} = T/2 - \sqrt{T^{2}/4-D}$ and $\lambda_2=T/2
    + \sqrt{T^{2}/4-D}$ then\vspace*{-0.3cm}
    {\small
    \begin{align*}
      \lambda_{1} + \lambda_{2} &= T
      &&&
      \lambda_{1} \times \lambda_{2} = D\pause
    \end{align*}\vspace*{-0.7cm}
  \end{itemize}
\end{PauseHighLight}

\end{slide}


