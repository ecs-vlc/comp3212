\begin{slide}
\section{Exponential Deviates}

\begin{PauseHighLight}
  \begin{itemize}
  \item For exponential deviates we generate a random deviate
    $U\sim\mathrm{Uni}(0,1)$\pause
  \item Then to generate $X\sim\mathrm{Exp}(x|1)=\e{-x}$ (with $F_X(x|1)
    = 1-\e{-x}$) we use
    \begin{align*}
      X = F_X^{-1}(U) = -\log(1-U)\pause
    \end{align*}
  \item To draw a random deviate $T \sim \mathrm{Exp}(t|a) =
    a\,\exp(-a\,t)$ we just rescale $T = X/a$\pause
  \item That is, $T=-\log(1-U)/a$\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Gillespie's Algorithm}

\begin{PauseHighLight}
  \begin{itemize}
  \item To simulate a reaction equation we take $\bm{X}(t) =
    (X_1(t),\,X_2(t),\,\ldots,\,X_N(t))$ to be the count of molecules at
    time $t$\pause
  \item We assume we  have $K$ reactions which we label $R_j$\pause
  \item The probability of a reaction occurring in a volume $V$ in
    time interval $[t,t+\dd t]$ we denote by
    $a_j(\bm{X}(t))\,\dd t$---this is known as the propensity\pause
  \item The propensity is equal to the reaction rate times the product
    of concentrations of chemical species that react together (i.e. on
    the left-hand side) times the volume\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Gillespie's Algorithm Continued}

\begin{PauseHighLight}
  \begin{itemize}
  \item We compute the total propensity $a_0(\bm{X}(t)) = \sum_{j=1}^K
    a_i(\bm{X}(t))$\pause
  \item We draw a random time $T\sim \mathrm{Exp(t|a_0)}$ using
    \begin{align*}
      T &= - \frac{1}{a_0} \log(1-U) & U&\sim\mathrm{Uni}(0,1)\pause
    \end{align*}
  \item We select the reaction that happened with probabilities
    \begin{align*}
      \Prob{j} = \frac{a_j}{a_0}\pause
    \end{align*}
  \item We update the molecule number according to what reaction has
    happened\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

