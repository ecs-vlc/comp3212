\begin{slide}
\section{Discrete Dynamic Models}

\begin{PauseHighLight}
  \begin{itemize}
  \item We would like to simulate the set of chemical reactions
    \begin{align*}
      \varnothing &\goesto{k_1} A  &
      \varnothing &\goesto{k_2} B & 
       A + B &\goesto{k_3} C &
       C &\goesto{k_4} A + B\pause
    \end{align*}
  \item At each time we want to keep note of the number of molecules
    $A(t)$, $B(t)$, $C(t)$\pause
  \item These number only change when a reaction happens\pause
  \item When the numbers change the probability of a reaction
    changes\pause
  \item Events that happen at particular points in space or time are
    known as \emph{point processes}\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

