\begin{slide}
\section{Probabilities of Reaction}

\begin{PauseHighLight}
  \begin{itemize}
  \item For the reactions
    \begin{align*}
      \varnothing &\goesto{k_1} A  &
      \varnothing &\goesto{k_2} B & 
       A + B &\goesto{k_3} C &
       C &\goesto{k_4} A + B\pause
    \end{align*}
  \item The probability of a reaction in time $\delta t$ is
    \begin{itemize}
    \item $\Prob{\varnothing \goesto{k_1} A} = k_1\,\delta t$
    \item $\Prob{\varnothing \goesto{k_2} B} = k_2\,\delta t$
    \item $\Prob{A + B \goesto{k_3} C} = k_3\,A\,B\,\delta t/\Omega$
    \item $\Prob{C \goesto{k_4} A + B} = k_4\,C\,\delta t$
    \end{itemize}
    where $\Omega$ is the volume of reactants\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}



