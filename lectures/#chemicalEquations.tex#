\begin{slide}
\section[-2]{Poisson Processes}

\begin{PauseHighLight}
  \begin{itemize}
  \item Suppose we have a point process with a probability of occurring
    in time $\delta t$ of $a\, \delta t$\pause
  \item The probability of the first occurrence happening in time interval
    $n\,\delta t \leq t \leq (n+1)\,\delta t$ is \hspace{6cm}\makebox(0,0){\includegraphics[width=10cm]{poisson_process}}
    \begin{align*}
      \Prob{n\,\delta t \leq t \leq (n+1)\,\delta t}
      &= (1-a \,\delta t)^n \,a \, \delta\,t\pause
      = a \, \e{n\log(1-a \,\delta t)} \, \delta t\pause\\
      &\approx a \, \e{-a\,n \,\delta t} \, \delta t\pause
      \approx a \, \e{-a\,t} \, \delta t\pause
    \end{align*}
    \pauselevel{=4} since $\log(1+\Delta) \approx \Delta +O(\Delta^2)$\pause\pauselevel{=6}
  \item If we take the limit $\delta t\rightarrow 0$ then
    \begin{align*}
      f_T(t) = \lim_{\delta t\rightarrow 0} \frac{\Prob{n\,\delta
  t \leq t \leq (n+1)\,\delta t}}{\delta t}\pause = a\,\e{-a\,t}\pauseb
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-2]{Multiple Poisson Processes}

\begin{PauseHighLight}
  \begin{itemize}
  \item If there are $K$ event with probability of occurring in time
    $\delta t$ of $a_i\,\delta t$ then the probability of any one
    of them happening in time $\delta t$ is $a_0 \,\delta t$ where
    $a_0=\sum_{i=1}^K a_i$\pause
    {\footnotesize
    \begin{align*}
      \Biggl( 1-\Prob{\forall_i \mathcal{E}_i}
      &= 1 - \prod_i (1-a_i \delta t)
        = 1 - (1-a_1\,\delta t)(1-a_2\,\delta t)\cdots  (1-a_K\,\delta t)
      \\
       &= 1 - \biggl( 1 -\delta t \sum_i a_i + (\delta t)^2 \sum_{i\neq j} a_i\,a_j + \cdots\biggr)
        = \sum_i a_i \delta t +  O((\delta t)^2) \Biggr)\pause
    \end{align*}}
  \item Thus the distribution of time, $T$, of the first event is given
    by
    \begin{align*}
      f_T(t) = a_0\,\e{-a_0\,t}\pause
    \end{align*}
  \item The probability of that first even being event $i$ is
    \begin{align*}
      \Prob{\text{first event is event $i$}} =
      \frac{a_i}{a_1+\cdots+a_K} = \frac{a_i}{a_0}\pause
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}

