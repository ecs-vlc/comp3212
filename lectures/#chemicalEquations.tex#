\begin{slide}
\section[-2]{Probability of Reaction $2\,X + Y \goesto{k} 3 \,X$}

\begin{leftImage}[0.4]{smallVolume}
  \begin{PauseHighLight}
    \begin{align*}
      \Prob{Y_i \in \delta V} = \frac{\delta V}{V}\pause
    \end{align*}
    \begin{itemize}
    \item If we have $n$ particles of type $Y$ the probability of at
      least one being in $\delta V$ is
      $n\,\delta V/V = [Y]\,\delta V$\pause
    \end{itemize}
  \end{PauseHighLight}
\end{leftImage}
\begin{PauseHighLight}
  \begin{itemize}
  \item The probability of two particles $X_1$ and $X_2$ both being in
    $\delta V$ is $\left(\frac{\delta V}{V}\right)^2$\pause
  \item If we have $m$ particles of type $X$ the probability of at
    least 
    two being in $\delta V$ is $\frac{m\,(m-1)}{2}\left(\frac{\delta
        V}{V}\right)^2\approx \frac{(\delta V)^2}{2}\,[X]^2$\pause 
  \end{itemize}
\end{PauseHighLight}


\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-2]{Probability of Reaction $2\,X + Y \goesto{k} 3 X$}

\begin{PauseHighLight}
  \begin{itemize}
  \item Probability of one particle of type $Y$ and two particles of
    type $X$ being in volume $\delta V$ is proportionals to
    \begin{align*}
      [Y]\,[X]^2 (\delta V)^3\pause
    \end{align*}
  \item The number of $\delta V$'s in $V$ is $N=V/\delta V$\pause
  \item The probability of a reaction in $V$ is proportional to
    \begin{align*}
      N\,[Y]\,[X]^2 (\delta V)^3 = V \, [Y]\,[X]^2 \,  (\delta V)^2\pause
    \end{align*}
  \item The expected number of reactions per unit volume is proportional to
    \begin{align*}
      [Y]\,[X]^2\pause
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section{Reaction Rate}

\begin{PauseHighLight}
  \begin{itemize}
  \item A chemist would measure the rate of change of concentration
    $[X]$ for the reaction and divide by $[Y]\,[X]^2$ to come up with a
    reaction rate $k$\pause
    \begin{align*}
      2\,X + Y \goesto{k} 3 X \\
      \frac{\dd [X]}{\dd t} = k \, [Y]\,[X]^2\pause
    \end{align*}
  \item The chemist would measure concentrations in moles per litre
    ($\text{mol}\, dm^{-3}$)\pause
  \end{itemize}
\end{PauseHighLight}

\end{slide}

%%%%%%%%%%%%%%%%%%%%%%% Next Slide %%%%%%%%%%%%%%%%%%%%%%%

\begin{slide}
\section[-2]{Concentration to Numbers}

\begin{PauseHighLight}
  \begin{itemize}
  \item To work in numbers of molecules, $X$, we use $[X] =
    X/\Omega$\pause
  \item $\Omega = V \times A$, where $V$ is volume and $A$ Avogadro's
    number
    \begin{align*}
      \frac{\dd [X]}{\dd t} = k [Y]\,[X]^2\pause\\
      \frac{1}{\Omega} \frac{\dd X}{\dd t} = k \frac{1}{\Omega^3}
      Y\,X^2\pause\\
      \frac{\dd X}{\dd t} = \frac{k}{\Omega^2} Y\,X^2\pause
    \end{align*}
  \item If we want to be even more accurate the probability of a
    reaction taking place in time $\delta t$ is
    \begin{align*}
      \frac{k}{\Omega^2} Y\,X\,(X-1)\pause
    \end{align*}
  \end{itemize}
\end{PauseHighLight}

\end{slide}



